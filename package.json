{
  "name": "remo-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "NODE_ENV=production bun src/index.ts",
    "build": "bun build ./src/index.html --outdir ./dist --public-path ./ && cp -r public/. dist/"
  },
  "dependencies": {
    "@stackflow/config": "^1.2.2",
    "@stackflow/core": "^1.3.2",
    "@stackflow/plugin-basic-ui": "^1.18.1",
    "@stackflow/plugin-history-sync": "^1.10.1",
    "@stackflow/plugin-renderer-basic": "^1.1.13",
    "@stackflow/react": "^1.12.0",
    "@tanstack/react-query": "^5.100.14",
    "@wanteddev/wds": "^3.6.0",
    "@wanteddev/wds-icon": "^3.6.0",
    "framer-motion": "^12.40.0",
    "msw": "^2.14.6",
    "react": "^19",
    "react-dom": "^19",
    "react-router-dom": "^7.15.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-router-dom": "^5.3.3"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}